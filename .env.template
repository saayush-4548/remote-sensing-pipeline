# ============================================================
# SATELLITE PIPELINE - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and edit values for your mill.
# Change ONLY this file - all scripts read from here.
#
# Usage: cp .env.template .env  →  edit .env  →  python run_pipeline.py
# ============================================================

# ------------------------------------------------------------
# SUPABASE CREDENTIALS
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# MILL (INGENIO) SELECTION
# One of: Pantaleon | Monte_Rosa | Amajac | EMSA | IPSA
# ------------------------------------------------------------
INGENIO=Monte_Rosa

# ------------------------------------------------------------
# DATE CONFIGURATION
# FECHA_INICIO / FECHA_FIN : 5-day search window for S2 inference image
# FECHAS                   : Comma-separated processing dates (YYYY-M-D)
# ------------------------------------------------------------
FECHA_INICIO=2026-02-22
FECHA_FIN=2026-02-25
FECHAS=2026-2-24

# ------------------------------------------------------------
# PRODUCTS TO PROCESS
# Comma-separated: NDVI,NDWI,SMART_GROWTH,WEED
# ------------------------------------------------------------
PRODUCTOS=NDVI,NDWI,SMART_GROWTH,WEED

# ------------------------------------------------------------
# DIRECTORY PATHS
# OUT_DIR    : Download destination (pairs/ and cloud_free_output/ go here)
# INPUT_DIR  : Where renamed cloudfill TIFs are placed (for processing)
# OUTPUT_DIR : Where parquet outputs and rasters are saved
# ------------------------------------------------------------
OUT_DIR=monterosa-auto
INPUT_DIR=inputs-monterosa-auto
OUTPUT_DIR=Output-monterosa

# ------------------------------------------------------------
# EXCEL SYNC
# ------------------------------------------------------------
EXCEL_PATH=Plantillas-new.xlsx
BD_INSERT=false
DRY_RUN_SYNC=false

# ------------------------------------------------------------
# SKIP FLAGS  (set true to skip a step when re-running)
# ------------------------------------------------------------
SKIP_DOWNLOAD=false
SKIP_CLOUD_REMOVAL=false
SKIP_RENAME=false
SKIP_PROCESSING=false
SKIP_DB_PUSH=false

# ------------------------------------------------------------
# AWS / S3  (used by setup_dependencies.py to fetch static files)
# Leave blank if using IAM role / instance profile instead.
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=carrier-pdfs
S3_PREFIX=stomasense-dependencies
