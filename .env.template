# ============================================================
# SATELLITE PIPELINE - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and edit the values below.
# Only these fields need to change between runs:
#
#   INGENIO       — which mill to process
#   FECHA_INICIO  — start of the S2 search window
#   FECHA_FIN     — end of the S2 search window
#   FECHAS        — comma-separated processing date(s)
#
# ALL paths (OUT_DIR, INPUT_DIR, OUTPUT_DIR, AOI, NAME_CONFIG...)
# are auto-derived from INGENIO. Do NOT set them here.
# ============================================================

# ------------------------------------------------------------
# SUPABASE CREDENTIALS
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# MILL SELECTION
# One of: Pantaleon | Monte_Rosa | Amajac | EMSA | IPSA
# ------------------------------------------------------------
INGENIO=Monte_Rosa

# ------------------------------------------------------------
# DATE CONFIGURATION
# FECHA_INICIO / FECHA_FIN : 5-day search window for S2 inference image
# FECHAS                   : Comma-separated processing dates (YYYY-M-D)
#                            Use comma for multiple dates: 2026-2-9,2026-2-14
# ------------------------------------------------------------
FECHA_INICIO=2026-02-22
FECHA_FIN=2026-02-25
FECHAS=2026-2-24

# ------------------------------------------------------------
# PRODUCTS TO PROCESS (optional — defaults to all 4)
# ------------------------------------------------------------
PRODUCTOS=NDVI,NDWI,SMART_GROWTH,WEED

# ------------------------------------------------------------
# EXCEL SYNC
# ------------------------------------------------------------
EXCEL_PATH=Plantillas-new.xlsx
BD_INSERT=false
DRY_RUN_SYNC=false

# ------------------------------------------------------------
# SKIP FLAGS  (set true to resume a failed run from a specific step)
# ------------------------------------------------------------
SKIP_DOWNLOAD=false
SKIP_CLOUD_REMOVAL=false
SKIP_RENAME=false
SKIP_PROCESSING=false
SKIP_DB_PUSH=false

# ------------------------------------------------------------
# AWS / S3  (used by setup_dependencies.py to fetch static files)
# Leave blank if using IAM role / instance profile instead.
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=carrier-pdfs
S3_PREFIX=stomasense-dependencies
